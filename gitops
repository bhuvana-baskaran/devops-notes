your-project/
├── inventory.ini          # or hosts.yml
├── group_vars/            # ← this folder
│   ├── all.yml            # variables for EVERY host
│   ├── webservers.yml     # variables only for group [webservers]
│   ├── dbservers.yml      # variables only for group [dbservers]
│   ├── production.yml     # variables only for group [production]
│   └── staging.yml        # variables only for group [staging]
├── host_vars/             # ← optional, for single hosts
│   └── server1.example.com.yml ## exact same name of the host
└── playbook.yml

