#!/bin/bash

WATCH_DIR="/home"
BACKUP_DIR="/backup/directory"
LOG_FILE="log.txt"

mkdir -p "$BACKUP_DIR" - avoid errors if the directory already exists

inotifywait -m -e create "$WATCH_DIR" --format '%w%f' | while read NEWFILE
do
    echo "$NEWFILE - $(date)" >> "$LOG_FILE"
    BASENAME=$(basename "$NEWFILE")
    tar -czf "$BASENAME.tar.gz" "$NEWFILE"
    mv "$BASENAME.tar.gz" "$BACKUP_DIR"
done
basename filename - prints the filename

inotifywait -m -e create "$WATCH_DIR" --format '%w%f'
inotifywait is part of inotify-tools (Linux utility for filesystem events).
-m → “monitor mode,” keeps running continuously.
-e create → watches for new file creation events.
--format '%w%f' → outputs the full path of the new file.
Example: If a file /home/test.txt is created, it prints /home/test.txt

